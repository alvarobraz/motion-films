generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  PENDING
  CONTACTED
  ARCHIVED
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  name     String
}

model Customer {
  id    String @id @default(cuid())
  name  String
  email String @unique
  phone String @unique
  lead  Lead?
}

model Lead {
  id          String     @id @default(cuid())
  requirement String
  message     String
  status      LeadStatus @default(PENDING)
  createdAt   DateTime   @default(now())

  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}
