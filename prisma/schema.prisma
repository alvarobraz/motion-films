generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum LeadStatus {
  PENDING
  CONTACTED
  ARCHIVED
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
  name     String
}

model Customer {
  id    String @id @default(cuid())
  name  String
  email String @unique
  phone String @unique
  leads Lead[]
}

model Lead {
  id          String   @id @default(cuid())
  requirement String
  message     String
  createdAt   DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
}
